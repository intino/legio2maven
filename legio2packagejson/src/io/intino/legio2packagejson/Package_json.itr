rule type(package)
    {
        "name": "$artifactId",
        "version": "$version",
        "description": "",
        "main": "src/App.js",
        "scripts": {
            "build": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' webpack --mode production",
                    "dev": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' webpack --mode development --watch"
        },
        "author": "",
        "license": "ISC",
        "devDependencies": {
            $packDependency+dependency...[,$NL]
        },
        "dependencies": {
            $dependency...[,$NL]
        },
        "resolutions" : {
        	$resolution...[,$NL]
        },
		"overrides" : {
			$resolution...[,$NL]
		}

    }

rule trigger(dependency)
     "$name": "$version"

rule trigger(resolution)
     "$name": "$version"

rule trigger(fsevents)
    "fsevents": "^2.1.2",